//
// Plan 01 E1-live — the interactive editor entry point.
//
// Launch (per CLAUDE.md § Key commands):
//   ~/Documents/loft/target/release/loft --lib ~/Documents/loft/lib src/main.loft
//
// Controls:
//   WASD              pan camera (held → debounced ~8 hexes/sec)
//   scroll wheel      zoom in/out
//   1..9, 0, -, =     select palette type (1=sea, 5=grass, 9=wall,
//                     0=wall_high; - and = reserved for indices 10
//                     and 11 as the palette grows past 9 types)
//   Left-click/drag   paint hovered hex with active type
//                     (ground mode) — in marker mode, single-click
//                     places a spawn at the hovered hex with the
//                     current place-direction; clicking on an
//                     existing marker removes it.
//   Tab               toggle Ground ↔ Marker mode; the badge in
//                     the top-right of the HUD shows the current
//                     mode (grass-green = Ground, hot pink = Marker).
//   R / Shift+R       (marker mode) rotate the place-direction
//                     clockwise / counter-clockwise (0..5, mod 6).
//                     A faint outline ghost arrow at the hovered
//                     hex previews where the next click will land.
//   Ctrl+S            save to dryopea_save.json
//   Ctrl+N            clear all — empty painted layer, empty
//                     marker layer, reset camera to origin.
//                     Does NOT auto-save; the next Ctrl+S
//                     commits the cleared state.
//   H                 recentre camera at origin (without clearing
//                     painted or marker layers).  Letter rather
//                     than `Home` because graphics.loft doesn't
//                     ship a KEY_HOME constant yet.
//   Esc               save + exit
//
// Hotkey strategy: 12 base slots (1234567890-=) cover the near-term
// palette growth.  Future expansion uses modifier engagers (Shift,
// Ctrl, Shift+Ctrl) × the 12 base keys = 48 slots, plenty of room
// without abandoning row-1 muscle memory.
//
// On startup, loads dryopea_save.json if it exists; otherwise
// starts on an empty (all-sea) world.  Saves on exit so paint
// progress isn't lost when the window is closed without Ctrl+S.

use dryopea;
use graphics;

const WINDOW_W: integer = 960;
const WINDOW_H: integer = 720;
const PPM: float = 24.0;
const SAVE_PATH:        text = "dryopea_save.json";
const MARKER_SAVE_PATH: text = "dryopea_save_markers.json";

// Debounce thresholds in microseconds (`ticks()` is microsecond-
// precision).  Held keys fire at the rates below, not 60Hz.
const PAN_DEBOUNCE_US:   integer = 120000;   // ~8 hexes/sec
const PAINT_DEBOUNCE_US: integer = 50000;    // ~20 hexes/sec
const SAVE_DEBOUNCE_US:  integer = 500000;   // 2 saves/sec max

// ASCII key codes that loft's graphics:: lib doesn't expose as
// symbolic KEY_* constants yet — graphics.loft has 0-9 + a
// handful of named letters (W A S D Q E O R F Z Y) but not all
// row-letters and no `-` / `=`.  Loft's key constants ARE the
// lowercase ASCII codes (`KEY_W = 119`, etc.); follow the same
// convention.  The dedicated `Home` key isn't in graphics.loft
// today either — using letter `H` instead for camera recentre.
const KEY_MINUS: integer = 45;    // ASCII '-' — palette index 10
const KEY_EQUAL: integer = 61;    // ASCII '=' — palette index 11
const KEY_N:     integer = 110;   // ASCII 'n' — Ctrl+N clears all
const KEY_H:     integer = 104;   // ASCII 'h' — recentre camera

fn main() {
    if !gl_create_window(WINDOW_W, WINDOW_H, "dryopea editor") {
        println("dryopea: failed to open window");
        return;
    }
    painter = create_painter_2d(WINDOW_W as float, WINDOW_H as float);

    palette = load_palette("examples/palette.json");
    picker = picker_default("examples/palette.json");

    loaded = load_map_or_empty(SAVE_PATH, palette);
    pw  = loaded.0;
    cam = loaded.1;
    mw  = load_markers_or_empty(MARKER_SAVE_PATH);
    println("dryopea: editor open ({painted_count(pw)} hexes, {marker_count(mw)} markers loaded)");

    last_pan_us:   integer = 0;
    last_paint_us: integer = 0;
    last_save_us:  integer = 0;

    // Drag-paint state.  At PAINT_DEBOUNCE_US = 50ms (20Hz),
    // the mouse can move several hexes between paint events
    // during a fast drag.  Connecting consecutive paint events
    // with paint_line fills the gaps; `painting` distinguishes
    // a continuation from the start of a new stroke so a release-
    // then-quick-repress doesn't bridge two separate strokes.
    painting:       boolean = false;
    last_paint_hex: Hex     = Hex { q: 0, r: 0 };

    // Editor mode + edge-detected Tab.  Tab held down across many
    // frames must NOT oscillate the mode at 60Hz — track previous-
    // frame state and only toggle on the rising edge.
    mode:          integer = MODE_GROUND;
    tab_held_prev: boolean = false;

    // Marker-mode placement state.  `place_direction` is the
    // rotation applied to the NEXT spawn marker placement.
    // R / Shift+R rotate it (edge-detected; held key doesn't spin).
    // `mb_held_prev` edge-detects the left button so a held mouse
    // doesn't ping-pong place→remove every frame on the same hex.
    place_direction: u8      = 0 as u8;
    r_held_prev:     boolean = false;
    mb_held_prev:    boolean = false;

    // Save-state tracking.  `dirty` flips to true on every paint /
    // place / remove / clear and back to false on a successful
    // save.  The HUD save indicator reads this directly.  Other
    // edge-detected modifier keys (Ctrl+N, H) also live here.
    dirty:        boolean = false;
    n_held_prev:  boolean = false;
    h_held_prev:  boolean = false;

    for _ in 0..1000000 {
        if !gl_poll_events() { break; }
        if gl_key_pressed(graphics::KEY_ESCAPE) { break; }

        tnow = ticks();

        // ── Input ───────────────────────────────────────────────

        ctrl_held = gl_key_pressed(graphics::KEY_CTRL);
        wheel = gl_mouse_wheel();

        // Tab → toggle Ground ↔ Marker (edge-detected; held key
        // doesn't oscillate).
        tab_now = gl_key_pressed(graphics::KEY_TAB);
        if tab_now && !tab_held_prev {
            mode = toggle_mode(mode);
            // Reset stroke + placement edge-detection on mode flip so
            // a held button doesn't bleed across the boundary.
            painting     = false;
            mb_held_prev = false;
            println("dryopea: mode = {mode_name(mode)}");
        }
        tab_held_prev = tab_now;

        // R / Shift+R (marker mode only) — rotate the place-
        // direction.  Edge-detected so held R doesn't spin.
        shift_held = gl_key_pressed(graphics::KEY_SHIFT);
        r_now      = gl_key_pressed(graphics::KEY_R);
        if r_now && !r_held_prev && mode == MODE_MARKER {
            place_direction = rotate_direction(
                place_direction,
                if shift_held { -1 } else { 1 }
            );
            println("dryopea: place_direction = {place_direction as integer}");
        }
        r_held_prev = r_now;

        // Ctrl+S → save (debounced to avoid Ctrl+S held-down spam).
        if ctrl_held && gl_key_pressed(graphics::KEY_S) {
            if tnow - last_save_us > SAVE_DEBOUNCE_US {
                save_world(pw, cam, palette, "interactive", SAVE_PATH);
                save_markers(mw, "interactive", MARKER_SAVE_PATH);
                last_save_us = tnow;
                dirty = false;
                println("dryopea: saved ({painted_count(pw)} hexes, {marker_count(mw)} markers)");
            }
        }

        // Ctrl+N → clear all.  Resets the editor's in-memory
        // state to a fresh world.  Does NOT auto-save; the next
        // Ctrl+S commits the cleared state.  Edge-detected so a
        // held Ctrl+N doesn't re-clear every frame.
        n_now = gl_key_pressed(KEY_N);
        if ctrl_held && n_now && !n_held_prev {
            pw    = painted_empty();
            mw    = marker_empty();
            cam   = camera_default();
            dirty = true;
            painting     = false;
            mb_held_prev = false;
            println("dryopea: cleared all (Ctrl+N)");
        }
        n_held_prev = n_now;

        // H → recentre camera (without disturbing painted or
        // marker layers).  Edge-detected so a held H doesn't
        // fire every frame.  Skip if Ctrl is held — that's the
        // Ctrl+H combination, not single-H.
        h_now = gl_key_pressed(KEY_H);
        if h_now && !h_held_prev && !ctrl_held {
            cam = camera_default();
            println("dryopea: camera recentred (H)");
        }
        h_held_prev = h_now;

        // Camera pan + zoom.  Pan-south is suppressed when Ctrl is
        // held so Ctrl+S doesn't also pan.
        if tnow - last_pan_us > PAN_DEBOUNCE_US {
            in_state = InputState {
                in_pan_north: gl_key_pressed(graphics::KEY_W),
                in_pan_south: gl_key_pressed(graphics::KEY_S) && !ctrl_held,
                in_pan_east:  gl_key_pressed(graphics::KEY_D),
                in_pan_west:  gl_key_pressed(graphics::KEY_A),
                in_zoom_in:   wheel > 0,
                in_zoom_out:  wheel < 0,
            };
            if in_state.in_pan_north || in_state.in_pan_south
            || in_state.in_pan_east  || in_state.in_pan_west
            || in_state.in_zoom_in   || in_state.in_zoom_out {
                camera_update(cam, in_state);
                last_pan_us = tnow;
            }
        }

        // Picker hotkeys.  Idempotent — held keys re-set to the
        // same index, no need to debounce.
        if gl_key_pressed(graphics::KEY_1) { picker_set_active(picker, 0); }
        if gl_key_pressed(graphics::KEY_2) { picker_set_active(picker, 1); }
        if gl_key_pressed(graphics::KEY_3) { picker_set_active(picker, 2); }
        if gl_key_pressed(graphics::KEY_4) { picker_set_active(picker, 3); }
        if gl_key_pressed(graphics::KEY_5) { picker_set_active(picker, 4); }
        if gl_key_pressed(graphics::KEY_6) { picker_set_active(picker, 5); }
        if gl_key_pressed(graphics::KEY_7) { picker_set_active(picker, 6); }
        if gl_key_pressed(graphics::KEY_8) { picker_set_active(picker, 7); }
        if gl_key_pressed(graphics::KEY_9) { picker_set_active(picker, 8); }
        if gl_key_pressed(graphics::KEY_0) { picker_set_active(picker, 9); }
        if gl_key_pressed(KEY_MINUS)       { picker_set_active(picker, 10); }
        if gl_key_pressed(KEY_EQUAL)       { picker_set_active(picker, 11); }

        // Mouse — hover + paint on left-button.
        mx = gl_mouse_x() as integer;
        my = gl_mouse_y() as integer;
        hovered = screen_to_hex(cam, mx, my, WINDOW_W, WINDOW_H, PPM);

        mb_now = (gl_mouse_button() & 1) != 0;

        if mb_now && mode == MODE_GROUND {
            // Ground-mode paint: writes to the painted-hex layer.
            if tnow - last_paint_us > PAINT_DEBOUNCE_US {
                if painting {
                    // Continuation of a drag — fill the gap from
                    // the previous paint hex to the current hovered
                    // hex (paint_line handles same-hex as a no-op
                    // single paint, so this is safe even when the
                    // mouse barely moved).
                    paint_line(pw, last_paint_hex, hovered, picker.active as u8);
                } else {
                    // Start of a new stroke — single hex.
                    paint(pw, hovered.q, hovered.r, picker.active as u8);
                }
                last_paint_hex = hovered;
                painting       = true;
                last_paint_us  = tnow;
                dirty          = true;
            }
        } else {
            // Ground-mode stroke ended (button released, hover left,
            // or mode flipped); next press starts a fresh stroke.
            painting = false;
        }

        if mb_now && !mb_held_prev && mode == MODE_MARKER {
            // Marker-mode is edge-triggered: each press is one
            // place-or-remove event, not a drag.  Click an existing
            // marker → remove (toggle behaviour the plan README
            // calls for); click an empty hex → place a spawn with
            // the current rotation.
            if has_marker(mw, hovered.q, hovered.r) {
                remove_marker(mw, hovered.q, hovered.r);
                println("dryopea: removed marker at ({hovered.q}, {hovered.r})");
            } else {
                place_spawn(mw, hovered.q, hovered.r, place_direction);
                println("dryopea: placed spawn at ({hovered.q}, {hovered.r}) dir={place_direction as integer}");
            }
            dirty = true;
        }
        mb_held_prev = mb_now;

        // ── Render ──────────────────────────────────────────────

        // Ground mode: hover shows a PREVIEW of the next paint
        // (hex filled with active palette colour + outline).
        // Marker mode: just the plain hover outline + the ghost
        // arrow (markers don't replace ground colour, so the
        // paint-preview would be misleading).
        if mode == MODE_GROUND {
            cv = render_with_hover_preview(cam, pw, hovered,
                                            picker.active as u8,
                                            WINDOW_W, WINDOW_H, PPM);
        } else {
            cv = render_with_hover(cam, pw, hovered,
                                    WINDOW_W, WINDOW_H, PPM);
        }
        render_markers(cv, cam, mw, WINDOW_W, WINDOW_H, PPM);
        // Marker-mode ghost preview at the hovered hex — only when
        // the hex is empty (placing on an occupied hex removes, so
        // no preview).
        if mode == MODE_MARKER && !has_marker(mw, hovered.q, hovered.r) {
            render_ghost_arrow(cv, cam, hovered.q, hovered.r,
                               place_direction, WINDOW_W, WINDOW_H, PPM);
        }
        render_picker(cv, picker, 12, 12);
        // Save indicator sits to the right of the picker, vertically
        // aligned with the top swatch.
        render_save_indicator(cv, dirty,
                              12 + PICKER_SWATCH_PX + 2 + SAVE_INDICATOR_RADIUS,
                              12 + SAVE_INDICATOR_RADIUS);
        render_mode_indicator(cv, mode, WINDOW_W - MODE_BADGE_PX - 12, 12);

        tex = gl_upload_canvas(cv.data, cv.width, cv.height);
        gl_clear(rgb(0, 0, 0));
        draw_texture_at(painter, tex, 0.0, 0.0, WINDOW_W as float, WINDOW_H as float);
        gl_delete_texture(tex);

        gl_swap_buffers();
    }

    // Save on exit so progress isn't lost when the window closes.
    save_world(pw, cam, palette, "exit", SAVE_PATH);
    save_markers(mw, "exit", MARKER_SAVE_PATH);
    dirty = false;
    println("dryopea: saved on exit ({painted_count(pw)} hexes, {marker_count(mw)} markers)");
    gl_destroy_window();
}
