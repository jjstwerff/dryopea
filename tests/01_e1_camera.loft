//
// Plan 01 phase E1 — camera + world primitives.
//
// Pattern: moros (lib/moros_*/tests/*.loft).  Each test builds
// state from factories (camera_default / input_empty), calls a
// pure tick, asserts on state fields.  No graphics / OS / IO.

use dryopea;

// ─────────────────────────────────────────────────────────────────
// World math
// ─────────────────────────────────────────────────────────────────

fn test_hex_to_world_origin() {
    th_xy = hex_to_world(Hex { q: 0, r: 0 });
    assert(th_xy.0 == 0.0, "origin x = 0");
    assert(th_xy.1 == 0.0, "origin y = 0");
}

fn test_hex_to_world_q1() {
    // q=1 shifts world.x by HEX_DIAMETER * 0.75 = 1.125
    tw_xy = hex_to_world(Hex { q: 1, r: 0 });
    tw_dx = tw_xy.0 - 1.125;
    assert(abs(tw_dx) < 0.0001, "q=1 → x ≈ 1.125");
    // q=1, r=0 shifts world.y by FLAT_TO_FLAT * 0.5 ≈ 0.6495
    tw_dy = tw_xy.1 - 0.6495;
    assert(abs(tw_dy) < 0.001, "q=1,r=0 → y ≈ 0.6495");
}

fn test_hex_distance_origin() {
    assert(hex_distance(Hex { q: 0, r: 0 }, Hex { q: 0, r: 0 }) == 0,
           "distance to self = 0");
    assert(hex_distance(Hex { q: 0, r: 0 }, Hex { q: 1, r: 0 }) == 1,
           "adjacent = 1");
    assert(hex_distance(Hex { q: 0, r: 0 }, Hex { q: 3, r: 0 }) == 3,
           "three steps east = 3");
}

fn test_hex_distance_diagonal() {
    // (0,0) to (2,-1) — axial diagonal: dq=2, dr=-1, ds=-1
    // (|2|+|-1|+|-1|)/2 = 4/2 = 2
    td_d = hex_distance(Hex { q: 0, r: 0 }, Hex { q: 2, r: -1 });
    assert(td_d == 2, "axial diagonal distance");
}

// Hex disc count for radius N is 1 + 3*N*(N+1):
//   N=0 → 1, N=1 → 7, N=2 → 19, N=3 → 37
fn test_visible_hexes_disc_size() {
    tv_origin = Hex { q: 0, r: 0 };
    assert(len(visible_hexes(tv_origin, 0)) == 1,  "haze=0 → 1 hex");
    assert(len(visible_hexes(tv_origin, 1)) == 7,  "haze=1 → 7 hexes");
    assert(len(visible_hexes(tv_origin, 2)) == 19, "haze=2 → 19 hexes");
    assert(len(visible_hexes(tv_origin, 3)) == 37, "haze=3 → 37 hexes");
}

// ─────────────────────────────────────────────────────────────────
// Camera
// ─────────────────────────────────────────────────────────────────

fn test_camera_default() {
    tc_d = camera_default();
    assert(tc_d.pos.q == 0, "default camera q = 0");
    assert(tc_d.pos.r == 0, "default camera r = 0");
    assert(tc_d.zoom  == 1, "default camera zoom = 1");
}

fn test_camera_pan_north() {
    tc_n = camera_default();
    tc_ni = input_empty();
    tc_ni.in_pan_north = true;
    camera_update(tc_n, tc_ni);
    assert(tc_n.pos.r == -1, "pan-north decreases r");
    assert(tc_n.pos.q ==  0, "pan-north leaves q alone");
}

fn test_camera_pan_south() {
    tc_s = camera_default();
    tc_si = input_empty();
    tc_si.in_pan_south = true;
    camera_update(tc_s, tc_si);
    assert(tc_s.pos.r == 1, "pan-south increases r");
}

fn test_camera_pan_east_west() {
    tc_e = camera_default();
    tc_ei = input_empty();
    tc_ei.in_pan_east = true;
    camera_update(tc_e, tc_ei);
    assert(tc_e.pos.q == 1, "pan-east increases q");

    tc_w = camera_default();
    tc_wi = input_empty();
    tc_wi.in_pan_west = true;
    camera_update(tc_w, tc_wi);
    assert(tc_w.pos.q == -1, "pan-west decreases q");
}

fn test_camera_multi_pan() {
    // Multiple directions in one tick all apply.
    tc_m = camera_default();
    tc_mi = input_empty();
    tc_mi.in_pan_north = true;
    tc_mi.in_pan_east  = true;
    camera_update(tc_m, tc_mi);
    assert(tc_m.pos.q ==  1, "diagonal east+north → q=1");
    assert(tc_m.pos.r == -1, "diagonal east+north → r=-1");
}

fn test_camera_zoom() {
    tc_z = camera_default();
    tc_zi = input_empty();

    // Zoom out: zoom value increases
    tc_zi.in_zoom_out = true;
    camera_update(tc_z, tc_zi);
    assert(tc_z.zoom == 2, "zoom-out increments zoom");

    // Zoom in: zoom value decreases
    tc_zi = input_empty();
    tc_zi.in_zoom_in = true;
    camera_update(tc_z, tc_zi);
    assert(tc_z.zoom == 1, "zoom-in decrements zoom");

    // Clamp at ZOOM_MIN = 1
    camera_update(tc_z, tc_zi);
    assert(tc_z.zoom == 1, "zoom-in clamps at ZOOM_MIN");
}

fn test_camera_no_input_noop() {
    tc_q = camera_default();
    tc_qi = input_empty();
    camera_update(tc_q, tc_qi);
    assert(tc_q.pos.q == 0, "empty input → q unchanged");
    assert(tc_q.pos.r == 0, "empty input → r unchanged");
    assert(tc_q.zoom  == 1, "empty input → zoom unchanged");
}

fn test_camera_at_specific() {
    tc_a = camera_at(5, -3, 2);
    assert(tc_a.pos.q ==  5, "camera_at q");
    assert(tc_a.pos.r == -3, "camera_at r");
    assert(tc_a.zoom  ==  2, "camera_at zoom");
}

// ─────────────────────────────────────────────────────────────────
// World-to-hex (inverse of hex_to_world) — round-trips
// ─────────────────────────────────────────────────────────────────

fn test_world_to_hex_origin() {
    tw_h = world_to_hex(0.0, 0.0);
    assert(tw_h.q == 0, "origin → q=0");
    assert(tw_h.r == 0, "origin → r=0");
}

fn test_world_to_hex_roundtrip_axes() {
    // Forward then inverse should land on the same hex.
    tw_xy1 = hex_to_world(Hex { q: 1, r: 0 });
    tw_h1 = world_to_hex(tw_xy1.0, tw_xy1.1);
    assert(tw_h1.q == 1, "round-trip (1,0) → q=1");
    assert(tw_h1.r == 0, "round-trip (1,0) → r=0");

    tw_xy2 = hex_to_world(Hex { q: 0, r: 1 });
    tw_h2 = world_to_hex(tw_xy2.0, tw_xy2.1);
    assert(tw_h2.q == 0, "round-trip (0,1) → q=0");
    assert(tw_h2.r == 1, "round-trip (0,1) → r=1");

    tw_xy3 = hex_to_world(Hex { q: 2, r: -1 });
    tw_h3 = world_to_hex(tw_xy3.0, tw_xy3.1);
    assert(tw_h3.q ==  2, "round-trip (2,-1) → q=2");
    assert(tw_h3.r == -1, "round-trip (2,-1) → r=-1");
}

fn test_world_to_hex_near_centre() {
    // Points very close to a hex centre map to that hex.
    tw_c = hex_to_world(Hex { q: 3, r: 2 });
    tw_h = world_to_hex(tw_c.0 + 0.05, tw_c.1 - 0.05);
    assert(tw_h.q == 3, "near-centre offset still picks (3,2).q");
    assert(tw_h.r == 2, "near-centre offset still picks (3,2).r");
}

// ─────────────────────────────────────────────────────────────────
// Painted layer — sparse storage
// ─────────────────────────────────────────────────────────────────

fn test_painted_default_is_sea() {
    tp_w = painted_empty();
    assert(painted_count(tp_w) == 0, "fresh world has 0 painted hexes");
    assert(lookup_painted(tp_w, 0, 0)   == 0 as u8, "miss returns sea (0)");
    assert(lookup_painted(tp_w, 99, 99) == 0 as u8, "any unpainted returns sea");
}

fn test_painted_paint_and_lookup() {
    tp_p = painted_empty();
    paint(tp_p, 0, 0, 5 as u8);   // grass at origin
    paint(tp_p, 1, 0, 9 as u8);   // wall east of origin
    assert(painted_count(tp_p) == 2, "two painted");
    assert(lookup_painted(tp_p, 0, 0) == 5 as u8, "origin = grass");
    assert(lookup_painted(tp_p, 1, 0) == 9 as u8, "east = wall");
    assert(lookup_painted(tp_p, 0, 1) == 0 as u8, "unpainted neighbour = sea");
}

fn test_painted_repaint_overwrites() {
    tp_o = painted_empty();
    paint(tp_o, 0, 0, 5 as u8);
    paint(tp_o, 0, 0, 7 as u8);     // overwrite grass with rock
    assert(painted_count(tp_o) == 1, "still one entry");
    assert(lookup_painted(tp_o, 0, 0) == 7 as u8, "now rock");
}

fn test_painted_paint_sea_erases() {
    tp_e = painted_empty();
    paint(tp_e, 0, 0, 5 as u8);
    assert(painted_count(tp_e) == 1, "one painted");
    paint(tp_e, 0, 0, 0 as u8);    // sea = remove
    assert(painted_count(tp_e) == 0, "erased back to empty");
    assert(lookup_painted(tp_e, 0, 0) == 0 as u8, "lookup returns sea");
}
