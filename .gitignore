# macOS
.DS_Store

# Editor / IDE
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# loft build / cache (placeholder; refine when build pipeline lands)
target/
build/
dist/
.cache/

# Generated docs
doc/*.html

# Local test outputs
*.log
result.txt
/tmp/

# Golden-image tests: actual outputs are regenerated every run;
# only the goldens are checked in.
tests/actual/

# Loft's native-compile + interpret cache directories — generated
# binaries / bytecode, regenerated per build.  Both root-level and
# src-level locations.
.loft/
src/.loft/

# Interactive-editor default-slot save (E1-live writes
# dryopea_save.json + the marker sidecar to the cwd when
# launched without a MAP= argument).  Named maps under
# maps/ are intentional repo content — authors commit
# them as authored.
dryopea_save.json
dryopea_save_markers.json
